# --- General ---
NODE_ENV=production
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=https://nexsmsid.dev,https://admin.nexsmsid.dev

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://nexsmsid:strongpassword@localhost:5432/nexsmsid?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379
# or
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Authentication ---
# Generate strong secrets: openssl rand -base64 64
JWT_ACCESS_SECRET=your-super-long-access-secret-minimum-64-chars
JWT_REFRESH_SECRET=your-super-long-refresh-secret-minimum-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Rate Limiting ---
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# --- Storage ---
# Use absolute paths in production
STORAGE_PATH=/app/storage
REPORT_STORAGE_PATH=/app/storage/reports

# --- Logging ---
# Levels: error, warn, log, debug, verbose
LOG_LEVEL=log

# --- Seed (Development Only) ---
SEED_SUPER_ADMIN_EMAIL=superadmin@nexsmsid.dev
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_NAME=Super Admin NexSMSID

# --- Web Frontend ---
NEXT_PUBLIC_API_URL=https://api.nexsmsid.dev/api/v1
WEB_PORT=3000
