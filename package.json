{
  "name": "nexsmsid",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml build",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "db:migrate:prod": "pnpm --filter @nexsmsid/api prisma migrate deploy",
    "db:seed:prod": "pnpm --filter @nexsmsid/api prisma db seed",
    "backup": "bash scripts/backup-postgres.sh",
    "restore": "bash scripts/restore-postgres.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.17.0"
  }
}
