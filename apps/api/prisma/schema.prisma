generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  username      String?        @unique
  name          String
  passwordHash  String         @map("password_hash")
  status        UserStatus     @default(ACTIVE)
  lastLoginAt   DateTime?      @map("last_login_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  roles                UserRole[]
  refreshTokens        RefreshToken[]
  auditLogs            AuditLog[]            @relation("AuditActor")
  verifiedPayments     Payment[]             @relation("VerifiedPayments")
  approvedExpenses     Expense[]             @relation("ApprovedExpenses")
  ppdbRegistrations    PpdbRegistration[]    @relation("PpdbVerifier")
  ppdbStatusChanges    PpdbStatusHistory[]   @relation("PpdbStatusChanger")
  reviewedInternshipLogs InternshipLog[]      @relation("InternshipLogReviewer")
  assessedInternshipScores InternshipScore[]  @relation("InternshipScoreAssessor")

  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  group       String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?  @map("actor_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SchoolProfile {
  id            String   @id @default(cuid())
  name          String
  npsn          String?
  address       String?
  phone         String?
  email         String?
  website       String?
  principalName String?  @map("principal_name")
  logoUrl       String?  @map("logo_url")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("school_profiles")
}

model AcademicYear {
  id        String     @id @default(cuid())
  name      String
  startDate DateTime   @map("start_date")
  endDate   DateTime   @map("end_date")
  isActive  Boolean    @default(false) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")
  semesters Semester[]
  teachingAssignments TeachingAssignment[]
  invoices Invoice[]
  ppdbPeriods PpdbPeriod[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("academic_years")
}

model Semester {
  id             String       @id @default(cuid())
  academicYearId String       @map("academic_year_id")
  name           String
  order          Int
  startDate      DateTime     @map("start_date")
  endDate        DateTime     @map("end_date")
  isActive       Boolean      @default(false) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  academicYear   AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  teachingAssignments TeachingAssignment[]
  invoices Invoice[]

  @@index([academicYearId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("semesters")
}

model Department {
  id           String       @id @default(cuid())
  code         String       @unique
  name         String
  description  String?
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  competencies Competency[]
  ppdbRegistrations PpdbRegistration[] @relation("PpdbDepartment")

  @@index([isActive])
  @@index([deletedAt])
  @@map("departments")
}

model Competency {
  id           String      @id @default(cuid())
  departmentId String      @map("department_id")
  code         String      @unique
  name         String
  description  String?
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  classrooms   Classroom[]
  ppdbRegistrations PpdbRegistration[] @relation("PpdbCompetency")

  @@index([departmentId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("competencies")
}

model Classroom {
  id           String     @id @default(cuid())
  competencyId String     @map("competency_id")
  code         String     @unique
  name         String
  level        Int
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Restrict)
  students     Student[]
  teachingAssignments TeachingAssignment[]

  @@index([competencyId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("classrooms")
}

model Room {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  type      String?
  capacity  Int?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  schedules Schedule[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("rooms")
}

model Subject {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  group     String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  teachingAssignments TeachingAssignment[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("subjects")
}

model LessonHour {
  id        String    @id @default(cuid())
  name      String
  order     Int
  startTime String    @map("start_time")
  endTime   String    @map("end_time")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  schedules Schedule[]

  @@index([order])
  @@index([isActive])
  @@index([deletedAt])
  @@map("lesson_hours")
}

model PaymentCategory {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  description   String?
  defaultAmount Int       @default(0) @map("default_amount")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  invoiceItems  InvoiceItem[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("payment_categories")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  PERMIT
  SICK
}

enum AssessmentType {
  DAILY
  ASSIGNMENT
  QUIZ
  MIDTERM
  FINAL
  PRACTICAL
  PROJECT
}

enum GradeStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PUBLISHED
}

model TeachingAssignment {
  id             String       @id @default(cuid())
  teacherId      String       @map("teacher_id")
  subjectId      String       @map("subject_id")
  classroomId    String       @map("classroom_id")
  academicYearId String       @map("academic_year_id")
  semesterId     String       @map("semester_id")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  teacher        Teacher      @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  classroom      Classroom    @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  semester       Semester     @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  schedules      Schedule[]
  assessments    Assessment[]

  @@unique([teacherId, subjectId, classroomId, semesterId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([classroomId])
  @@index([academicYearId])
  @@index([semesterId])
  @@index([deletedAt])
  @@map("teaching_assignments")
}

model Schedule {
  id                   String             @id @default(cuid())
  teachingAssignmentId String             @map("teaching_assignment_id")
  roomId               String             @map("room_id")
  lessonHourId         String             @map("lesson_hour_id")
  dayOfWeek            DayOfWeek          @map("day_of_week")
  isActive             Boolean            @default(true) @map("is_active")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  deletedAt            DateTime?          @map("deleted_at")
  teachingAssignment   TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  room                 Room               @relation(fields: [roomId], references: [id], onDelete: Restrict)
  lessonHour           LessonHour         @relation(fields: [lessonHourId], references: [id], onDelete: Restrict)
  attendanceSessions   AttendanceSession[]

  @@unique([roomId, dayOfWeek, lessonHourId])
  @@unique([lessonHourId, dayOfWeek, teachingAssignmentId])
  @@index([teachingAssignmentId])
  @@index([roomId])
  @@index([lessonHourId])
  @@index([dayOfWeek])
  @@index([deletedAt])
  @@map("schedules")
}

model AttendanceSession {
  id          String             @id @default(cuid())
  scheduleId  String             @map("schedule_id")
  date        DateTime           @map("date")
  topic       String?
  notes       String?
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")
  schedule    Schedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  records     AttendanceRecord[]

  @@unique([scheduleId, date])
  @@index([scheduleId])
  @@index([date])
  @@index([deletedAt])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id               String           @id @default(cuid())
  sessionId        String           @map("session_id")
  studentId        String           @map("student_id")
  status           AttendanceStatus @default(PRESENT)
  note             String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  session          AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student          Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@map("attendance_records")
}

model Assessment {
  id                   String         @id @default(cuid())
  teachingAssignmentId String         @map("teaching_assignment_id")
  name                 String
  type                 AssessmentType @default(DAILY)
  maxScore             Int            @default(100) @map("max_score")
  weight               Int            @default(1)
  description          String?
  dueDate              DateTime?      @map("due_date")
  isActive             Boolean        @default(true) @map("is_active")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  deletedAt            DateTime?      @map("deleted_at")
  teachingAssignment   TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  grades               Grade[]

  @@index([teachingAssignmentId])
  @@index([deletedAt])
  @@map("assessments")
}

model Grade {
  id           String       @id @default(cuid())
  assessmentId String       @map("assessment_id")
  studentId    String       @map("student_id")
  score        Int
  status       GradeStatus  @default(DRAFT)
  notes        String?
  gradedById   String?      @map("graded_by_id")
  gradedAt     DateTime?    @map("graded_at")
  approvedById String?      @map("approved_by_id")
  approvedAt   DateTime?    @map("approved_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, studentId])
  @@index([assessmentId])
  @@index([studentId])
  @@index([status])
  @@map("grades")
}

enum Gender {
  MALE
  FEMALE
}

enum PersonStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  RESIGNED
}

enum EmploymentStatus {
  PERMANENT
  CONTRACT
  HONORARY
  PROBATION
}

enum GuardianRelation {
  FATHER
  MOTHER
  GUARDIAN
  GRANDPARENT
  SIBLING
  OTHER
}

model Student {
  id           String      @id @default(cuid())
  nis          String      @unique
  nisn         String?     @unique
  name         String
  gender       Gender
  birthPlace   String?     @map("birth_place")
  birthDate    DateTime?   @map("birth_date")
  address      String?
  phone        String?
  email        String?     @unique
  classroomId  String?     @map("classroom_id")
  status       PersonStatus @default(ACTIVE)
  photoUrl     String?     @map("photo_url")
  enrolledAt   DateTime?   @map("enrolled_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")
  classroom            Classroom?         @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  guardians            StudentGuardian[]
  attendanceRecords    AttendanceRecord[]
  grades               Grade[]
  invoices             Invoice[]
  ppdbRegistrations    PpdbRegistration[] @relation("ConvertedStudent")
  internships          Internship[]
  alumni               Alumni?          @relation("StudentAlumni")

  @@index([classroomId])
  @@index([status])
  @@index([deletedAt])
  @@index([name])
  @@map("students")
}

model Guardian {
  id          String      @id @default(cuid())
  name        String
  relation    GuardianRelation
  phone       String
  email       String?     @unique
  occupation  String?
  address     String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  students    StudentGuardian[]

  @@index([name])
  @@map("guardians")
}

model StudentGuardian {
  studentId  String   @map("student_id")
  guardianId String   @map("guardian_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian   Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@id([studentId, guardianId])
  @@index([guardianId])
  @@map("student_guardians")
}

model Teacher {
  id              String      @id @default(cuid())
  nip             String?     @unique
  nuptk           String?     @unique
  name            String
  gender          Gender
  birthPlace      String?     @map("birth_place")
  birthDate       DateTime?   @map("birth_date")
  phone           String?
  email           String?     @unique
  address         String?
  employmentStatus EmploymentStatus @default(PERMANENT) @map("employment_status")
  status          PersonStatus @default(ACTIVE)
  photoUrl        String?     @map("photo_url")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")
  teachingAssignments TeachingAssignment[]
  supervisedInternships Internship[] @relation("InternshipSupervisor")

  @@index([status])
  @@index([deletedAt])
  @@index([name])
  @@map("teachers")
}

model Staff {
  id              String      @id @default(cuid())
  nip             String?     @unique
  name            String
  gender          Gender
  phone           String?
  email           String?     @unique
  address         String?
  position        String
  department      String?
  employmentStatus EmploymentStatus @default(PERMANENT) @map("employment_status")
  status          PersonStatus @default(ACTIVE)
  photoUrl        String?     @map("photo_url")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  @@index([status])
  @@index([deletedAt])
  @@index([name])
  @@index([position])
  @@map("staffs")
}

// Phase 8 - Finance
enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  QRIS
  OTHER
}

enum ExpenseStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique @map("invoice_number")
  studentId       String        @map("student_id")
  academicYearId  String?       @map("academic_year_id")
  semesterId      String?       @map("semester_id")
  issueDate       DateTime      @map("issue_date")
  dueDate         DateTime?     @map("due_date")
  subtotal        Decimal       @default(0) @map("subtotal")
  discount        Decimal       @default(0) @map("discount")
  penalty         Decimal       @default(0) @map("penalty")
  total           Decimal       @default(0) @map("total")
  paidAmount      Decimal       @default(0) @map("paid_amount")
  status          InvoiceStatus @default(DRAFT)
  note            String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  student        Student        @relation(fields: [studentId], references: [id])
  academicYear   AcademicYear?  @relation(fields: [academicYearId], references: [id])
  semester       Semester?      @relation(fields: [semesterId], references: [id])
  items          InvoiceItem[]
  payments       Payment[]

  @@index([studentId])
  @@index([status])
  @@index([deletedAt])
  @@map("invoices")
}

model InvoiceItem {
  id                 String          @id @default(cuid())
  invoiceId          String          @map("invoice_id")
  paymentCategoryId  String?         @map("payment_category_id")
  name               String
  quantity           Int             @default(1)
  unitPrice          Decimal         @map("unit_price")
  total              Decimal         @map("total")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  invoice          Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentCategory  PaymentCategory? @relation(fields: [paymentCategoryId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id              String        @id @default(cuid())
  paymentNumber   String        @unique @map("payment_number")
  invoiceId       String        @map("invoice_id")
  amount          Decimal       @map("amount")
  method          PaymentMethod @default(CASH)
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime      @default(now()) @map("paid_at")
  verifiedAt      DateTime?     @map("verified_at")
  verifiedById    String?       @map("verified_by_id")
  proofUrl        String?       @map("proof_url")
  note            String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  verifiedBy User?   @relation("VerifiedPayments", fields: [verifiedById], references: [id])

  @@index([invoiceId])
  @@index([status])
  @@map("payments")
}

model Expense {
  id            String        @id @default(cuid())
  expenseNumber String        @unique @map("expense_number")
  title         String
  category      String
  amount        Decimal       @map("amount")
  date          DateTime      @default(now()) @map("date")
  status        ExpenseStatus @default(DRAFT)
  approvedById  String?       @map("approved_by_id")
  note          String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  approvedBy User? @relation("ApprovedExpenses", fields: [approvedById], references: [id])

  @@index([status])
  @@index([deletedAt])
  @@map("expenses")
}

// Phase 8 - PPDB
enum PpdbRegistrationStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  REVISION
  ACCEPTED
  REJECTED
  CONVERTED
}

enum PpdbDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PpdbSelectionStatus {
  PENDING
  PASSED
  FAILED
}

model PpdbPeriod {
  id              String    @id @default(cuid())
  name            String
  academicYearId  String?   @map("academic_year_id")
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  isActive        Boolean   @default(true) @map("is_active")
  quota           Int?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  academicYear AcademicYear?        @relation(fields: [academicYearId], references: [id])
  registrations PpdbRegistration[]

  @@index([isActive])
  @@map("ppdb_periods")
}

model PpdbRegistration {
  id                   String                  @id @default(cuid())
  registrationNumber   String                  @unique @map("registration_number")
  periodId             String                  @map("period_id")
  name                 String
  gender               Gender
  birthPlace           String?                 @map("birth_place")
  birthDate            DateTime?               @map("birth_date")
  address              String?
  phone                String
  email                String?
  previousSchool       String?                 @map("previous_school")
  selectedDepartmentId String?                 @map("selected_department_id")
  selectedCompetencyId String?                 @map("selected_competency_id")
  status               PpdbRegistrationStatus  @default(DRAFT)
  selectionStatus      PpdbSelectionStatus     @default(PENDING) @map("selection_status")
  verifiedAt           DateTime?               @map("verified_at")
  verifiedById         String?                 @map("verified_by_id")
  convertedStudentId   String?                 @map("converted_student_id")
  note                 String?
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  period             PpdbPeriod          @relation(fields: [periodId], references: [id])
  selectedDepartment Department?         @relation("PpdbDepartment", fields: [selectedDepartmentId], references: [id])
  selectedCompetency Competency?         @relation("PpdbCompetency", fields: [selectedCompetencyId], references: [id])
  verifiedBy         User?               @relation("PpdbVerifier", fields: [verifiedById], references: [id])
  convertedStudent   Student?            @relation("ConvertedStudent", fields: [convertedStudentId], references: [id])
  documents          PpdbDocument[]
  statusHistory      PpdbStatusHistory[]

  @@index([periodId])
  @@index([status])
  @@index([convertedStudentId])
  @@map("ppdb_registrations")
}

model PpdbDocument {
  id             String              @id @default(cuid())
  registrationId String              @map("registration_id")
  name           String
  fileUrl        String              @map("file_url")
  status         PpdbDocumentStatus  @default(PENDING)
  note           String?
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  registration PpdbRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@map("ppdb_documents")
}

model PpdbStatusHistory {
  id             String                  @id @default(cuid())
  registrationId String                  @map("registration_id")
  fromStatus     PpdbRegistrationStatus? @map("from_status")
  toStatus       PpdbRegistrationStatus  @map("to_status")
  note           String?
  changedById    String?                 @map("changed_by_id")
  createdAt      DateTime                @default(now()) @map("created_at")

  registration PpdbRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  changedBy    User?            @relation("PpdbStatusChanger", fields: [changedById], references: [id])

  @@index([registrationId])
  @@map("ppdb_status_histories")
}

// Phase 9 - PKL, Alumni, BKK
enum PartnerStatus {
  ACTIVE
  INACTIVE
}

enum InternshipStatus {
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

enum InternshipLogStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  CANCELLED
}

enum JobApplicationStatus {
  SUBMITTED
  REVIEWED
  INTERVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum AlumniStatus {
  ACTIVE
  WORKING
  STUDYING
  ENTREPRENEUR
  UNEMPLOYED
  UNKNOWN
}

model IndustryPartner {
  id            String        @id @default(cuid())
  name          String
  type          String?
  contactPerson String?       @map("contact_person")
  phone         String?
  email         String?
  address       String?
  website       String?
  status        PartnerStatus @default(ACTIVE)
  note          String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  internships  Internship[]
  jobVacancies JobVacancy[]

  @@index([status])
  @@index([deletedAt])
  @@index([name])
  @@map("industry_partners")
}

model Internship {
  id                  String           @id @default(cuid())
  studentId           String           @map("student_id")
  industryPartnerId   String           @map("industry_partner_id")
  supervisorTeacherId String?          @map("supervisor_teacher_id")
  title               String
  startDate           DateTime         @map("start_date")
  endDate             DateTime         @map("end_date")
  status              InternshipStatus @default(PLANNED)
  finalScore          Decimal?         @map("final_score")
  note                String?
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  deletedAt           DateTime?        @map("deleted_at")

  student         Student         @relation(fields: [studentId], references: [id])
  industryPartner IndustryPartner @relation(fields: [industryPartnerId], references: [id])
  supervisor      Teacher?        @relation("InternshipSupervisor", fields: [supervisorTeacherId], references: [id])
  logs            InternshipLog[]
  score           InternshipScore?

  @@index([studentId])
  @@index([industryPartnerId])
  @@index([supervisorTeacherId])
  @@index([status])
  @@index([deletedAt])
  @@map("internships")
}

model InternshipLog {
  id            String              @id @default(cuid())
  internshipId  String              @map("internship_id")
  date          DateTime
  activity      String
  obstacle      String?
  solution      String?
  status        InternshipLogStatus @default(DRAFT)
  reviewedById  String?             @map("reviewed_by_id")
  reviewedAt    DateTime?           @map("reviewed_at")
  note          String?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  reviewedBy User?      @relation("InternshipLogReviewer", fields: [reviewedById], references: [id])

  @@index([internshipId])
  @@index([status])
  @@map("internship_logs")
}

model InternshipScore {
  id              String   @id @default(cuid())
  internshipId    String   @unique @map("internship_id")
  disciplineScore Int      @map("discipline_score")
  skillScore      Int      @map("skill_score")
  attitudeScore   Int      @map("attitude_score")
  reportScore     Int      @map("report_score")
  finalScore      Decimal  @map("final_score")
  assessedById    String?  @map("assessed_by_id")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  assessedBy User?      @relation("InternshipScoreAssessor", fields: [assessedById], references: [id])

  @@index([assessedById])
  @@map("internship_scores")
}

model Alumni {
  id              String       @id @default(cuid())
  studentId       String?      @unique @map("student_id")
  nis             String?
  name            String
  graduationYear  Int          @map("graduation_year")
  phone           String?
  email           String?
  address         String?
  status          AlumniStatus @default(UNKNOWN)
  currentCompany  String?      @map("current_company")
  currentPosition String?      @map("current_position")
  university      String?
  businessName    String?      @map("business_name")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  student         Student?         @relation("StudentAlumni", fields: [studentId], references: [id])
  jobApplications JobApplication[]
  tracerStudies   TracerStudy[]

  @@index([status])
  @@index([graduationYear])
  @@index([deletedAt])
  @@index([name])
  @@map("alumni")
}

model JobVacancy {
  id                String     @id @default(cuid())
  industryPartnerId String?    @map("industry_partner_id")
  title             String
  companyName       String     @map("company_name")
  description       String
  qualification     String?
  location          String?
  employmentType    String?    @map("employment_type")
  salaryRange       String?    @map("salary_range")
  deadline          DateTime?
  status            JobStatus  @default(DRAFT)
  publishedAt       DateTime?  @map("published_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  deletedAt         DateTime?  @map("deleted_at")

  industryPartner IndustryPartner? @relation(fields: [industryPartnerId], references: [id])
  applications    JobApplication[]

  @@index([industryPartnerId])
  @@index([status])
  @@index([deletedAt])
  @@index([deadline])
  @@map("job_vacancies")
}

model JobApplication {
  id             String               @id @default(cuid())
  jobVacancyId   String               @map("job_vacancy_id")
  alumniId       String?              @map("alumni_id")
  applicantName  String               @map("applicant_name")
  applicantEmail String?              @map("applicant_email")
  applicantPhone String?              @map("applicant_phone")
  cvUrl          String?              @map("cv_url")
  status         JobApplicationStatus @default(SUBMITTED)
  note           String?
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  jobVacancy JobVacancy @relation(fields: [jobVacancyId], references: [id], onDelete: Cascade)
  alumni     Alumni?    @relation(fields: [alumniId], references: [id])

  @@unique([jobVacancyId, applicantEmail])
  @@index([jobVacancyId])
  @@index([alumniId])
  @@index([status])
  @@map("job_applications")
}

model TracerStudy {
  id           String       @id @default(cuid())
  alumniId     String       @map("alumni_id")
  year         Int
  status       AlumniStatus @default(UNKNOWN)
  companyName  String?      @map("company_name")
  position     String?
  university   String?
  major        String?
  businessName String?      @map("business_name")
  incomeRange  String?      @map("income_range")
  feedback     String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  alumni Alumni @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([alumniId])
  @@index([year])
  @@index([status])
  @@map("tracer_studies")
}
